# Tanish — Environment Variables
# Copy to .env and fill in your values
# Railway auto-injects DATABASE_URL and REDIS_URL from plugins — don't set those manually.

# ============================================
# TELEGRAM
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=TanishBot

# ============================================
# DATABASE — Railway PostgreSQL plugin (auto-injected)
# Only set manually for local development
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/tanish

# ============================================
# REDIS — Railway Redis plugin (auto-injected)
# Only set manually for local development
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# AUTH
# ============================================
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ============================================
# URLS
# ============================================
WEBAPP_URL=https://tanish.uz
# Set these for production webhook mode (Railway sets RAILWAY_PUBLIC_DOMAIN automatically)
WEBHOOK_URL=
WEBHOOK_SECRET=

# ============================================
# SERVER
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# PHOTO STORAGE — Cloudflare R2 (S3-compatible, free egress)
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tanish-photos
R2_PUBLIC_URL=https://photos.tanish.uz

# ============================================
# ADMIN
# ============================================
ADMIN_TELEGRAM_IDS=123456789
ADMIN_GROUP_CHAT_ID=
# Comma-separated Telegram IDs for frontend admin access (AdminGuard in App.tsx)
VITE_ADMIN_IDS=123456789
