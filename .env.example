# Tanish — Environment Variables
# Copy to .env and fill in your values

# ============================================
# TELEGRAM
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=TanishBot

# ============================================
# DATABASE — Railway PostgreSQL (provisioned via Railway dashboard)
# Railway auto-injects DATABASE_URL when you add a PostgreSQL service
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/tanish

# ============================================
# REDIS — Railway Redis (provisioned via Railway dashboard)
# Railway auto-injects REDIS_URL when you add a Redis service
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# AUTH
# ============================================
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ============================================
# URLS
# ============================================
WEBAPP_URL=https://your-app-url.up.railway.app
API_URL=https://your-api-url.up.railway.app
BOT_WEBHOOK_URL=https://your-bot-url.up.railway.app/bot/webhook

# ============================================
# SERVER
# ============================================
NODE_ENV=development
API_PORT=3001
BOT_PORT=3002

# ============================================
# PHOTO STORAGE — Cloudflare R2 (S3-compatible, free egress)
# ============================================
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=tanish-photos
R2_PUBLIC_URL=https://photos.tanish.uz

# ============================================
# ADMIN
# ============================================
ADMIN_TELEGRAM_IDS=123456789,987654321

# ============================================
# INFRASTRUCTURE NOTES (no Supabase!)
# ============================================
# PostgreSQL  → Railway PostgreSQL plugin (free dev plan, $5/mo hobby)
# Redis       → Railway Redis plugin (free dev plan)
# Photo CDN   → Cloudflare R2 + Cloudflare CDN (free egress, 10GB free storage)
# Frontend    → Railway static site OR Cloudflare Pages (free)
# Backend API → Railway service (auto-deploy from GitHub)
# Bot         → Railway service (separate from API)
# Domain      → tanish.uz via Cloudflare DNS (free)
